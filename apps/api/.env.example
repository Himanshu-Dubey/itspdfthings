APP_NAME=PDFThings
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=loveupdf
DB_USERNAME=loveupdf
DB_PASSWORD=secret

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# ── CORS & Sanctum ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,127.0.0.1:3000,127.0.0.1:3001

# ── Queue & Cache ─────────────────────────────────────────────────────────────
QUEUE_CONNECTION=sync
CACHE_STORE=file
BROADCAST_CONNECTION=log

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Storage (Cloudflare R2 — S3-compatible) ──────────────────────────────────
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=itspdfthings-files
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=https://<your-r2-public-domain>

# ── PDF CLI tools (Windows local paths) ─────────────────────────────────────
PDF_TOOL_QPDF="C:\Program Files\qpdf 12.3.2\bin\qpdf.exe"
PDF_TOOL_GHOSTSCRIPT="C:\Users\<user>\scoop\shims\gswin64c.exe"
PDF_TOOL_IMAGEMAGICK="C:\Program Files\ImageMagick-7.1.2-Q16-HDRI\magick.exe"

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# ── Free-tier quotas ─────────────────────────────────────────────────────────
QUOTA_ANONYMOUS_PER_TOOL_DAY=3
QUOTA_FREE_USER_PER_TOOL_DAY=10

# ── File size limits (bytes) ─────────────────────────────────────────────────
FILE_SIZE_LIMIT_FREE=20971520
FILE_SIZE_LIMIT_PREMIUM=524288000

# ── Billing provider switch ───────────────────────────────────────────────────
BILLING_PROVIDER=stripe

# ── Stripe / Cashier billing ──────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
CASHIER_CURRENCY=usd
BILLING_SUCCESS_URL=http://localhost:3000/dashboard?upgraded=1
BILLING_CANCEL_URL=http://localhost:3000/pricing

# ── Razorpay billing ──────────────────────────────────────────────────────────
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
