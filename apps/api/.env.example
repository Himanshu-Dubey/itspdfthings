APP_NAME=PDFThings
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.itspdfthings.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: use Laragon's MySQL (port 3306). Docker prod: use the mysql service.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=loveupdf
DB_USERNAME=loveupdf
DB_PASSWORD=secret

# ── Session ───────────────────────────────────────────────────────────────────
# SESSION_DOMAIN covers both api. and app. subdomains (leading dot = all subdomains).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.itspdfthings.com
SESSION_SECURE_COOKIE=false     # Set true in production (HTTPS required).
SESSION_SAME_SITE=lax           # 'lax' works for same-eTLD+1 (api. ↔ app.).

# ── CORS & Sanctum ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://app.itspdfthings.com:3000
SANCTUM_STATEFUL_DOMAINS=app.itspdfthings.com,app.itspdfthings.com:3000

# ── Queue & Cache ─────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
CACHE_STORE=redis
BROADCAST_CONNECTION=log

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Object Storage (Cloudflare R2) ────────────────────────────────────────────
# Swap endpoint for AWS S3 or Backblaze B2 — no code changes needed.
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=itspdfthings-files
AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true
# AWS_URL=https://<your-r2-public-domain>  # Only needed if you have a public bucket domain.

# ── Rate limits (configurable without code changes) ───────────────────────────
RATE_LIMIT_UPLOADS_PER_MINUTE=10

# ── Free-tier quotas ─────────────────────────────────────────────────────────
QUOTA_ANONYMOUS_PER_TOOL_DAY=3
QUOTA_FREE_USER_PER_TOOL_DAY=10

# ── File size limits (bytes) ─────────────────────────────────────────────────
FILE_SIZE_LIMIT_FREE=20971520       # 20 MB
FILE_SIZE_LIMIT_PREMIUM=524288000   # 500 MB

# ── Billing provider switch ───────────────────────────────────────────────────
BILLING_PROVIDER=stripe             # "stripe" or "razorpay"

# ── Stripe / Cashier billing ─────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=       # Price ID from the Stripe Dashboard (price_...)
CASHIER_CURRENCY=usd
BILLING_SUCCESS_URL=http://app.itspdfthings.com:3000/dashboard?upgraded=1
BILLING_CANCEL_URL=http://app.itspdfthings.com:3000/pricing

# ── Razorpay billing ──────────────────────────────────────────────────────────
RAZORPAY_KEY=                       # Publishable Key ID (safe client-side)
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID=                   # Plan ID from the Razorpay Dashboard (plan_...)
